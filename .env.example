# Configurações do LinkedIn
LINKEDIN_EMAIL=seu_email@exemplo.com
LINKEDIN_PASSWORD=sua_senha

# Delay entre requisições em milissegundos (opcional, padrão: 2000)
REQUEST_DELAY_MS=2000

# Keywords para matching com pesos (formato: (palavras):peso ; separated)
# Exemplo: (.net, dotnet):2 significa que esse grupo tem peso 2
KEYWORDS="(.net, dotnet):2;(C#,c-sharp, csharp):3;(typescript, ts):1"

# OpenRouter API para análise de vagas
OPENROUTER_API_KEY="sua_api_key_aqui"
OPENROUTER_MODEL="stepfun/step-3.5-flash:free,openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,nvidia/nemotron-3-super-120b-a12b:free"